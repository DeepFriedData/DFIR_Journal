<Window x:Class="DFIRNode.Views.ImportBundleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Bundle" Height="420" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d1117">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Import Bundle" FontSize="20" FontWeight="SemiBold"
                       Foreground="#e6edf3" FontFamily="Segoe UI" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                       Foreground="#8b949e"
                       Text="Import a registration response or revocation bundle from the Domain Registrar."/>
        </StackPanel>
        <Border Grid.Row="1" Background="#161b22" BorderBrush="#30363d"
                BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="BUNDLE TYPE" Foreground="#8b949e" FontSize="10"
                           FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="RadioRegistration" Content="Registration Response"
                                 IsChecked="True" Foreground="#e6edf3"
                                 FontFamily="Segoe UI" FontSize="12" Margin="0,0,20,0"/>
                    <RadioButton x:Name="RadioRevocation" Content="Revocation Bundle"
                                 Foreground="#e6edf3" FontFamily="Segoe UI" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2">
            <TextBlock Text="BUNDLE FILE" Foreground="#8b949e" FontSize="11"
                       FontFamily="Segoe UI" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#0d1117" BorderBrush="#30363d"
                        BorderThickness="1" CornerRadius="4" Padding="10,8">
                    <TextBlock x:Name="FilePathText" Text="No file selected"
                               Foreground="#8b949e" FontFamily="Segoe UI" FontSize="12"/>
                </Border>
                <Button Grid.Column="2" Content="Browse..."
                        Background="#21262d" Foreground="#e6edf3"
                        BorderBrush="#30363d" BorderThickness="1"
                        Padding="16,8" Cursor="Hand" Click="Browse_Click"/>
            </Grid>
            <TextBlock Text="PREVIEW" Foreground="#8b949e" FontSize="11"
                       FontFamily="Segoe UI" Margin="0,0,0,6"/>
            <Border Background="#161b22" BorderBrush="#30363d" BorderThickness="1"
                    CornerRadius="4" Padding="12" Height="120">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="PreviewText" Foreground="#8b949e"
                               FontFamily="Consolas" FontSize="11"
                               TextWrapping="Wrap" Text="Select a file to preview..."/>
                </ScrollViewer>
            </Border>
            <TextBlock x:Name="ErrorText" Foreground="#f85149"
                       FontSize="12" FontFamily="Segoe UI"
                       Visibility="Collapsed" Margin="0,12,0,0" TextWrapping="Wrap"/>
            <TextBlock x:Name="SuccessText" Foreground="#3fb950"
                       FontSize="12" FontFamily="Segoe UI"
                       Visibility="Collapsed" Margin="0,12,0,0" TextWrapping="Wrap"/>
        </StackPanel>
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel"
                    Background="#21262d" Foreground="#e6edf3"
                    BorderBrush="#30363d" BorderThickness="1"
                    Padding="0,10" Cursor="Hand" Click="Cancel_Click"/>
            <Button Grid.Column="2" Content="Import Bundle"
                    x:Name="ImportBtn" Click="Import_Click"
                    IsEnabled="False" Background="#1f6feb" Foreground="White"
                    BorderThickness="0" Padding="0,10" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>